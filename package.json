{
  "name": "ai-documentary-video-generator",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/remotion"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "render": "npm run render --workspace packages/remotion",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "8.5.15",
    "ws": "8.21.0"
  }
}
