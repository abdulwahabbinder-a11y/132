# ============================================================================
# DocuForge AI — root environment template
# Copy to `.env` and fill in. Used by docker-compose for shared services.
# ============================================================================

# --- Postgres (local dev infra; Supabase manages this in production) ---
POSTGRES_USER=docuforge
POSTGRES_PASSWORD=docuforge
POSTGRES_DB=docuforge
POSTGRES_PORT=5432

# --- Redis (Celery broker + result backend) ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Backend / Frontend ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# See backend/.env.example and frontend/.env.local.example for service keys.
