# ══════════════════════════════════════════════════════════════════════════════
# DocuAI Platform — Environment Variables Template
# Copy this to .env and fill in real values before running.
# ══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-32-char-secret-key-change-this
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# PostgreSQL (Supabase connection pooler URL)
# Format: postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://docuai:docuai_secret@localhost:5432/docuai

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_PLAN_CREDITS=30
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# ─── NVIDIA NIM ───────────────────────────────────────────────────────────────
# Get from https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# Get from https://elevenlabs.io/settings
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Media APIs ───────────────────────────────────────────────────────────────
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key

# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-api-key

WIKIMEDIA_USER_AGENT=DocuAI/1.0 (your@email.com)

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Get from https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=pk.eyJ1...
REMOTION_MAPBOX_TOKEN=pk.eyJ1...
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ─── DeepVideo-V1 & LivePortrait (Optional) ────────────────────────────────────
# Configure when you have API access
DEEPVIDEO_API_KEY=
DEEPVIDEO_API_URL=
LIVEPORTRAIT_API_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
