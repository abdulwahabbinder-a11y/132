# ───────────────────────────────────────────────────────────
# Voice / Media APIs
# ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
PEXELS_API_KEY=
PIXABAY_API_KEY=
MAPBOX_TOKEN=

# ───────────────────────────────────────────────────────────
# Redis / Celery
# ───────────────────────────────────────────────────────────
