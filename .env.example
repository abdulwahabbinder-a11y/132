# =============================================================================
# DocuForge AI — Environment Configuration
# Copy to .env and fill in your API keys
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- NVIDIA NIM (Llama 3.1, Qwen 2.5, Flux, Wan2.1, DeepVideo-V1, LivePortrait) ---
NVIDIA_NIM_API_KEY=nvapi-...

# --- ElevenLabs ---
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Media & Scraping APIs ---
PEXELS_API_KEY=your-pexels-key
PIXABAY_API_KEY=your-pixabay-key
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token
TAVILY_API_KEY=tvly-...
JINA_API_KEY=jina_...
SERPER_API_KEY=...
FIRECRAWL_API_KEY=fc-...
EXA_API_KEY=...
BRAVE_SEARCH_API_KEY=...
NEWSAPI_KEY=...
CLAUDE_API_KEY=sk-ant-...

# --- App Config ---
FRONTEND_URL=https://docuforge.pro
CORS_ORIGINS=http://localhost:3000,https://docuforge.pro,https://www.docuforge.pro
NEXT_PUBLIC_SITE_URL=https://docuforge.pro
NEXT_PUBLIC_API_URL=http://localhost:8080/api
REDIS_URL=redis://localhost:6379/0
DEBUG=false

# --- Google Cloud (production) — see deploy/gcp/DEPLOY.md ---
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Demo admin (preview when Supabase not configured)
DEMO_ADMIN_EMAIL=support@docuforge.pro
# DEMO_ADMIN_PASSWORD=set-a-strong-password-here
CREDITS_PER_VIDEO=5
FREE_PLAN_CREDITS=5
PRO_PLAN_MONTHLY_CREDITS=30
ASSET_STORAGE_PATH=/tmp/docuforge/assets
OUTPUT_STORAGE_PATH=/tmp/docuforge/output
