# ============================================================================
# DocuForge AI — Environment Variables (copy to .env and fill in)
# ============================================================================

# ----- General -----
ENVIRONMENT=development               # development | staging | production
BACKEND_CORS_ORIGINS=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000

# ----- Supabase (Database + Auth + Storage) -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
SUPABASE_STORAGE_BUCKET=documentaries

# ----- Stripe (Billing) -----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO=price_xxx          # $29/month Pro plan price id
PRO_PLAN_MONTHLY_CREDITS=30

# ----- NVIDIA NIM (LLMs, Flux, Wan2.1, DeepVideo-V1) -----
NVIDIA_NIM_API_KEY=nvapi-xxx
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_LLM_MODEL_EN=meta/llama-3.1-70b-instruct
NIM_LLM_MODEL_INTL=qwen/qwen-2.5-72b-instruct
NIM_IMAGE_MODEL=stabilityai/flux-1-dev
NIM_VIDEO_MODEL=AnyFlow-Wan2.1-T2V-14B

# ----- ElevenLabs (Narration TTS) -----
ELEVENLABS_API_KEY=xxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ----- Media Scrapers -----
PEXELS_API_KEY=xxx
PIXABAY_API_KEY=xxx
WIKIMEDIA_USER_AGENT=DocuForgeAI/1.0 (contact@docuforge.ai)

# ----- Character Cinematics (self-hosted / inference endpoints) -----
LIVEPORTRAIT_ENDPOINT=http://localhost:9001/animate
DEEPVIDEO_V1_ENDPOINT=http://localhost:9002/synthesize

# ----- Maps -----
MAPBOX_ACCESS_TOKEN=pk.xxx

# ----- Async infra -----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ----- Rendering -----
REMOTION_PROJECT_DIR=../remotion
RENDER_OUTPUT_DIR=./storage/renders
FFMPEG_BINARY=ffmpeg

# ----- Frontend (Next.js public vars) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
