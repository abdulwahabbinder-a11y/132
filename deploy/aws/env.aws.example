# DocuForge — AWS production environment
# Store sensitive values in AWS Secrets Manager (see deploy/aws/setup-secrets.sh)

# --- Domains ---
FRONTEND_URL=https://docuforge.pro
CORS_ORIGINS=https://docuforge.pro,https://www.docuforge.pro
NEXT_PUBLIC_SITE_URL=https://docuforge.pro
NEXT_PUBLIC_API_URL=https://api.docuforge.pro/api

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
# Redis: Upstash (recommended) OR ElastiCache endpoint
REDIS_URL=rediss://default:PASSWORD@your-upstash-host.upstash.io:6379

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- AI & Media APIs ---
NVIDIA_NIM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
PEXELS_API_KEY=
PIXABAY_API_KEY=
MAPBOX_ACCESS_TOKEN=
TAVILY_API_KEY=
JINA_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
EXA_API_KEY=
BRAVE_SEARCH_API_KEY=
NEWSAPI_KEY=
CLAUDE_API_KEY=

# --- Storage (Fargate /tmp is ephemeral; use S3 for persistence later) ---
ASSET_STORAGE_PATH=/tmp/docuforge/assets
OUTPUT_STORAGE_PATH=/tmp/docuforge/output
DEBUG=false
