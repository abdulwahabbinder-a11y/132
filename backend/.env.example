###############################################################################
# AI Documentary Video Generator — Backend Environment
###############################################################################

# --- Core ---
APP_ENV=development
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
SECRET_KEY=replace-me-with-openssl-rand-hex-32

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
PRO_PLAN_CREDITS=30
FREE_PLAN_CREDITS=3

# --- NVIDIA NIM ---
NVIDIA_NIM_API_KEY=nvapi-...
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL_LLAMA=meta/llama-3.1-70b-instruct
NIM_MODEL_QWEN=qwen/qwen-2.5-72b-instruct
NIM_MODEL_FLUX=stabilityai/flux-1-dev
NIM_MODEL_WAN21=anyflow/wan2.1-t2v-14b
NIM_MODEL_DEEPVIDEO=deepvideo-v1
NIM_MODEL_LIVEPORTRAIT=liveportrait-v1

# --- ElevenLabs ---
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- Stock media scrapers ---
PEXELS_API_KEY=...
PIXABAY_API_KEY=...

# --- Maps ---
MAPBOX_ACCESS_TOKEN=pk.eyJ...

# --- Storage (S3-compatible / Supabase Storage) ---
STORAGE_BUCKET=documentary-videos
STORAGE_ENDPOINT=https://your-project.supabase.co/storage/v1
STORAGE_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Remotion render service ---
REMOTION_RENDERER_URL=http://localhost:3030
REMOTION_BUNDLE_PATH=/app/remotion

# --- FFmpeg ---
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
AUDIO_DUCK_DB=-15
