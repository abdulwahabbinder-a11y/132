# ============================================================================
# DocuForge AI — backend environment template
# ============================================================================

# --- App ---
APP_NAME=DocuForge AI
ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_URL=http://localhost:3000
SECRET_KEY=change-me-in-production
STORAGE_DIR=./storage

# --- Supabase (PostgreSQL + Auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO=price_xxx
DEFAULT_PRO_CREDITS=30

# --- NVIDIA NIM (LLMs + image/video models) ---
# Endpoints default to NVIDIA's hosted integrate.api.nvidia.com but can point
# at a self-hosted NIM microservice.
NVIDIA_NIM_API_KEY=nvapi-xxx
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL_LLAMA=meta/llama-3.1-70b-instruct
NIM_MODEL_QWEN=qwen/qwen-2.5-72b-instruct
NIM_MODEL_FLUX=stabilityai/flux-1-dev
NIM_MODEL_WAN=AnyFlow-Wan2.1-T2V-14B

# --- ElevenLabs ---
ELEVENLABS_API_KEY=xxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- Character cinematics (self-hosted GPU microservices) ---
LIVEPORTRAIT_ENDPOINT=http://liveportrait:8100
DEEPVIDEO_V1_ENDPOINT=http://deepvideo:8200

# --- Public media APIs ---
PEXELS_API_KEY=xxx
PIXABAY_API_KEY=xxx
WIKIMEDIA_USER_AGENT=DocuForgeAI/1.0 (contact@docuforge.ai)

# --- Maps ---
MAPBOX_ACCESS_TOKEN=pk.xxx
