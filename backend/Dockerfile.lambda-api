# Slim Lambda image — FastAPI API only (no FFmpeg / Remotion)
FROM public.ecr.aws/lambda/python:3.11

COPY backend/requirements.txt ${LAMBDA_TASK_ROOT}/requirements.txt
RUN pip install --no-cache-dir -r ${LAMBDA_TASK_ROOT}/requirements.txt mangum boto3

COPY backend/app ${LAMBDA_TASK_ROOT}/app

CMD ["app.lambda_api.handler"]
